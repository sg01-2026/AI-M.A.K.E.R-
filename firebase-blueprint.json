{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Resource": {
      "title": "Educational Resource",
      "description": "Uploaded image or PDF document metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "pdf"] },
        "fileUrl": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "authorId": { "type": "string" },
        "authorEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "fileUrl", "category"]
    },
    "ActivityPhoto": {
      "title": "Student Activity Photo",
      "description": "Activity photos shared by traditional clubs with detailed metadata and view counts",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["기본1 (기초)", "기본2(중급)", "기본3(고급)"] },
        "eventDate": { "type": "string" },
        "author": { "type": "string" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "imageUrl", "category", "eventDate", "author", "viewCount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Global resources shared across menus"
    },
    "/activity_photos/{photoId}": {
      "schema": "ActivityPhoto",
      "description": "Student activity photos separated by clubs with view count tracing"
    }
  }
}
