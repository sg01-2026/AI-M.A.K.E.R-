{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Resource": {
      "title": "Educational Resource",
      "description": "Uploaded image or PDF document metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "pdf"] },
        "fileUrl": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "authorId": { "type": "string" },
        "authorEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "fileUrl", "category"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Global resources shared across menus"
    }
  }
}
