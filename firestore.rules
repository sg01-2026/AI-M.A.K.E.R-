rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sg01@gge.goe.go.kr' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      request.resource.data.keys().hasAll(['uid', 'email', 'isAdmin', 'createdAt']) &&
                      (request.resource.data.isAdmin == false || request.resource.data.email == 'sg01@gge.goe.go.kr') && // Default admin email is allowed to be created as admin
                      request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email']));
      allow delete: if isAdmin();
    }

    // Resources (Images/PDFs)
    match /resources/{resourceId} {
      allow read, create, update, delete: if true;
    }

    // Student Activity Photos
    match /activity_photos/{photoId} {
      allow read, create, update, delete: if true;
    }
  }
}
